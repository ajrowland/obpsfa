{"hash":"890211902c648d888935f48fdb750be7150f7707","data":{"home":{"title":"Archive","path":"/archive","_rawBody":[{"_key":"b9d0ab57936a","_type":"block","children":[{"_key":"b9d0ab57936a0","_type":"span","marks":[],"text":"Documenting the days of District past"}],"markDefs":[],"style":"h2"},{"_key":"dc3b7d6076cf","_type":"block","children":[{"_key":"dc3b7d6076cf0","_type":"span","marks":[],"text":"We are currently rebuilding our site. This section in particular requires some work to add additional content and photos, to existing and new articles.  Please revisit for new content."}],"markDefs":[],"style":"normal"},{"_key":"45b6223dde16","_type":"block","children":[{"_key":"45b6223dde160","_type":"span","marks":[],"text":"If you have any content you would like to share, please send to: "},{"_key":"45b6223dde161","_type":"span","marks":["d03f7e5e2bc5"],"text":"mail@obpsfa.com"},{"_key":"45b6223dde162","_type":"span","marks":[],"text":""}],"markDefs":[{"_key":"d03f7e5e2bc5","_type":"link","href":"mailto:mail@obpsfa.com"}],"style":"normal"}],"mainImage":{"alt":"Black and white photo in a book","caption":"2003-2004 squad","attribution":null,"asset":{"_id":"image-850be9b171a1b3b98c628fcfb0f5e84fd984b61d-687x559-jpg","url":"https://cdn.sanity.io/images/7caqi88y/production/850be9b171a1b3b98c628fcfb0f5e84fd984b61d-687x559.jpg"}},"seo":{"description":"Photos and stories of the District.","author":{"name":"OBPSFA"},"image":null}},"archive":{"pageInfo":{"totalPages":8,"currentPage":1},"edges":[{"node":{"path":"/archive/2020-05-09-2019-2020-red-squad-gallery","id":"8f0db217-1580-4110-96ed-13b614a7c01d","title":"2019-2020 red squad gallery","date":"2020-05-09","mainImage":{"alt":"Photo of 2019-2020 red squad","caption":"2019-2020 red squad","attribution":null,"asset":null},"_rawBody":[{"_key":"fe23a67fb5d7","_type":"gallery","imgurId":"6KuX7bA"}],"seo":{"author":{"name":"OBPSFA"},"image":{"asset":{"_id":"image-ce8ea023d58c7dd4258183cd3932221a009d1fd8-1200x800-jpg","url":"https://cdn.sanity.io/images/7caqi88y/production/ce8ea023d58c7dd4258183cd3932221a009d1fd8-1200x800.jpg"}},"authorDisplay":null,"description":"Various photos of the 2019-2020 red squad."}}},{"node":{"path":"/archive/2020-05-09-2019-2020-blue-squad-gallery","id":"26fb1f77-7802-40eb-81f6-67993dc1f417","title":"2019-2020 blue squad gallery","date":"2020-05-09","mainImage":null,"_rawBody":[{"_key":"0581d9a75c36","_type":"gallery","imgurId":"hFdg3MD"}],"seo":{"author":{"name":"OBPSFA"},"image":{"asset":{"_id":"image-d0faf7aa3d659ae96a1ae0c386941e36d4de0822-1200x800-jpg","url":"https://cdn.sanity.io/images/7caqi88y/production/d0faf7aa3d659ae96a1ae0c386941e36d4de0822-1200x800.jpg"}},"authorDisplay":null,"description":"Various photos of the 2019-2020 blue squad."}}},{"node":{"path":"/archive/2020-03-06-reds-share-championship-cup","id":"b2c15b75-cc58-4d74-99ad-0c0db13bee1f","title":"Reds share Championship Cup","date":"2020-03-06","mainImage":{"alt":"Photo of 2019-2020 reds sqaud","caption":"Championship Cup winners","attribution":null,"asset":{"_id":"image-a5fc164881db06e47e494d52d9b164d1cfb81509-1200x1056-jpg","url":"https://cdn.sanity.io/images/7caqi88y/production/a5fc164881db06e47e494d52d9b164d1cfb81509-1200x1056.jpg"}},"_rawBody":[{"_key":"d23fc86a719a","_type":"block","children":[{"_key":"d23fc86a719a0","_type":"span","marks":[],"text":"Despite taking the lead against the Championship winning Bexley side, the Reds were unable to hold on to the outright win in the cup."}],"markDefs":[],"style":"normal"},{"_key":"382d6cee7d80","_type":"block","children":[{"_key":"382d6cee7d800","_type":"span","marks":[],"text":"Both teams share the cup, and should be very proud taking part in a fantastic match as the Gallagher Stadium."}],"markDefs":[],"style":"normal"},{"_key":"3a23dfffdb8d","_type":"block","children":[{"_key":"3a23dfffdb8d0","_type":"span","marks":[],"text":"Final score: 2-2 (George H, Riley)"}],"markDefs":[],"style":"normal"}],"seo":{"author":{"name":"Andrew Rowland"},"image":null,"authorDisplay":null,"description":"Despite taking the lead against the Championship winning Bexley side, the Reds were unable to hold on to the outright win in the cup."}}},{"node":{"path":"/archive/2017-04-30-jersey-2017-gallery","id":"cb801b70-df3d-410d-9d52-45c7251c0b1a","title":"Jersey 2017 gallery","date":"2017-04-30","mainImage":null,"_rawBody":[{"_key":"5733eaa80d8c","_type":"gallery","imgurId":"M3SjaoU"}],"seo":{"author":{"name":"OBPSFA"},"image":{"asset":{"_id":"image-8455b7d2e4b2aedc653c2b3ea6d364a82b3700f5-4608x3072-jpg","url":"https://cdn.sanity.io/images/7caqi88y/production/8455b7d2e4b2aedc653c2b3ea6d364a82b3700f5-4608x3072.jpg"}},"authorDisplay":null,"description":"Jersey 2017 gallery"}}},{"node":{"path":"/archive/2017-04-13-blues-report","id":"2017-04-13-e9b918ac2aff-page","title":"Blues report","date":"2017-04-13","mainImage":null,"_rawBody":[{"_key":"64b2b71035e4","_type":"block","children":[{"_key":"64b2b71035e40","_type":"span","marks":[],"text":"Due to the number of walking wounded, this feature is written by Dave ( Doctor Dave )"}],"markDefs":[],"style":"normal"},{"_key":"af9068e376f4","_type":"block","children":[{"_key":"af9068e376f40","_type":"span","marks":[],"text":"Blues as usual, felt the need to give the oppo an easy start, though I did feel 3 goals was stretching us, as we normally only pull back 2 goals."}],"markDefs":[],"style":"normal"},{"_key":"56a1f56d814a","_type":"block","children":[{"_key":"56a1f56d814a0","_type":"span","marks":[],"text":"A deft little header from Jack started our fight back, 3-1, with only 10 men standing, the pressure was on. A number of boys felt the rough edge of some very strong tackles from the home team. Bradley had had enough of watching the forwrds miss their chances and entered the box to show them how to finish. 3-2 game on."}],"markDefs":[],"style":"normal"},{"_key":"a2f16bc6cfb2","_type":"block","children":[{"_key":"a2f16bc6cfb20","_type":"span","marks":[],"text":"This target of 3 was just to high to reach in the amount of time we’d allowed ourselves. A 3-2 defeat against a very well organised Jersey team was not a result to be unhappy with, baring in mind how many had been affected by the bug going around the hotel."}],"markDefs":[],"style":"normal"},{"_key":"f00890b03e5c","_type":"block","children":[{"_key":"f00890b03e5c0","_type":"span","marks":[],"text":"We did ask the boys to remember you as they went “shopping” for souveniers , think they remembered that you had handed over the money, think most will NOT be receiving a gift from your cherubs lol."}],"markDefs":[],"style":"normal"},{"_key":"8c25b54f0c53","_type":"block","children":[{"_key":"8c25b54f0c530","_type":"span","marks":[],"text":"Nurse Fiona has doned her matron outfit and supplying Calpol to those that can keep it down."}],"markDefs":[],"style":"normal"},{"_key":"e8fac95ad9ef","_type":"block","children":[{"_key":"e8fac95ad9ef0","_type":"span","marks":[],"text":"Looking forward to our game against Gloucester tomorrow,not. Looks like I’ll playing at this rate with Mr Buller in Goal."}],"markDefs":[],"style":"normal"},{"_key":"806945f13dbc","_type":"block","children":[{"_key":"806945f13dbc0","_type":"span","marks":[],"text":"See you all Saturday at Gatwick"}],"markDefs":[],"style":"normal"}],"seo":{"author":null,"image":{"asset":{"_id":"image-a10bbd026c598ac065e1279f5bfc88dfd0a38a6f-1100x550-jpg","url":"https://cdn.sanity.io/images/7caqi88y/production/a10bbd026c598ac065e1279f5bfc88dfd0a38a6f-1100x550.jpg"}},"authorDisplay":"Dave","description":"Due to the number of walking wounded, this feature is written by Dave ( Doctor Dave )"}}}]},"metadata":{"siteTwitterName":"odpsfa","siteUrl":"https://www.obpsfa.com"}},"context":{}}